# ============================================================================
# AI Workflow Automation - Environment Configuration
# Copy to `.env` and fill values. Sensible defaults work out-of-the-box.
# ============================================================================

# ---- App ----
APP_NAME=AI Workflow Automation
APP_ENV=development                     # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_SECRET_KEY=change-me-to-a-long-random-string-32+chars
APP_PUBLIC_URL=http://localhost:8000

# ---- Storage / DB ----
# SQLite by default (zero-infra). To use Postgres set DATABASE_URL=postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:///./data/app.db
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
EXPORT_DIR=./data/exports
CHROMA_DIR=./data/chroma
GRAPH_DIR=./data/graph

# ---- Auth ----
JWT_ALGO=HS256
JWT_EXPIRES_MINUTES=720
BOOTSTRAP_ADMIN_EMAIL=admin@local.dev
BOOTSTRAP_ADMIN_PASSWORD=admin123

# ---- Free AI providers ----
# OpenRouter (https://openrouter.ai/keys) - generous free vision LLM tier
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Comma-separated rotation list. Free models tried first.
# Note: free model IDs change over time. Browse https://openrouter.ai/models?max_price=0 for current ones.
OPENROUTER_VISION_MODELS=google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,nvidia/nemotron-nano-12b-v2-vl:free,nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
OPENROUTER_TEXT_MODELS=qwen/qwen3-next-80b-a3b-instruct:free,deepseek/deepseek-v4-flash:free,openai/gpt-oss-120b:free,z-ai/glm-4.5-air:free

# HuggingFace Inference (https://huggingface.co/settings/tokens) - free
HF_API_TOKEN=
HF_BASE_URL=https://api-inference.huggingface.co/models
HF_OCR_MODEL=microsoft/trocr-large-handwritten
HF_TABLE_MODEL=microsoft/table-transformer-structure-recognition

# ---- Alternative free LLM providers (any one will work, listed in preference order) ----
# Ollama (local, fully free, unlimited). Install: https://ollama.com  then `ollama pull llama3.2-vision`
OLLAMA_BASE_URL=
OLLAMA_VISION_MODELS=llama3.2-vision:11b,llava:13b,qwen2-vl:7b
OLLAMA_TEXT_MODELS=llama3.1:8b,qwen2.5:7b,mistral:7b

# Groq (free 30 req/min, very fast). Get key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_VISION_MODELS=meta-llama/llama-4-scout-17b-16e-instruct,meta-llama/llama-4-maverick-17b-128e-instruct
GROQ_TEXT_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant,gemma2-9b-it

# Google AI Studio Gemini (free 15 req/min on flash). Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_VISION_MODELS=gemini-2.0-flash-exp,gemini-1.5-flash

# Together AI ($5 free credit). Get key: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_VISION_MODELS=meta-llama/Llama-Vision-Free,Qwen/Qwen2-VL-72B-Instruct
TOGETHER_TEXT_MODELS=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free,meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# Local embedding model (no API key, CPU-friendly)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Pipeline tuning ----
PIPELINE_MAX_WORKERS=2                  # asyncio worker count for job runner
PIPELINE_TIMEOUT_SEC=120
OCR_PROVIDER=auto                       # auto | openrouter | hf | tesseract
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=4
LLM_CACHE_ENABLED=true

# ---- Confidence thresholds (UI color coding) ----
CONF_GREEN_MIN=0.85
CONF_YELLOW_MIN=0.60

# ---- CORS / Frontend ----
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ---- Optional SMTP for trend reports ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@local

# ---- Webhooks (outbound) ----
WEBHOOK_TIMEOUT_SEC=10
